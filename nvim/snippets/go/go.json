{
  "Go File Header": {
    "prefix": "header",
    "body": [
      "/*",
      "* Copyright (c) $CURRENT_YEAR dev24hrs. All Rights Reserved.",
      "* The source code is released under the MIT License.",
      "* License that can be found in the LICENSE file.",
      "",
      "* AUTHOR : dev24hrs",
      "* TIME : $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE $CURRENT_HOUR:$CURRENT_MINUTE",
      "",
      "*/",
      "// Package ${TM_FILENAME_BASE} ${1:功能简述}"
    ],
    "description": "Header Comment in Go FILE."
  },
  "Slice Remove": {
    "prefix": "slicerm",
    "body": ["${1:slice} = append(${1:slice}[:${2:index}], ${1:slice}[${2:index}+1:]...)"],
    "description": "Slice Remove."
  },
  "Slice append": {
    "prefix": "sliceap",
    "body": ["${1:slice} = append(${1:slice}, ${0:element})"]
  },
  "If Ok": {
    "prefix": "ifok",
    "body": ["if ${1:value}, ok := $2; ok {", "  $0", "}"],
    "description": "if ok."
  },
  "GoMapWithValues": {
    "prefix": "mapva",
    "body": ["${1:mapname} := map[${2:keytype}]${3:valuetype}{", " \"${4:key1}\" : \"${5:value1}\", ", " \"${6:key2}\" : \"${7:value2}\", ", " \t$0", "}"],
    "description": "Declare var map with inference"
  },
  "Map Delete": {
    "prefix": "mapde",
    "body": ["delete(${1:map}, \"${2:key}\")"],
    "description": "Map Delete."
  },
  "if key in a map": {
    "prefix": "mapok",
    "body": "if ${1:value}, ok := ${2:map}[${3:key}]; ok {\n\t$4\n}",
    "description": "if key in a map."
  }
}
